# ==========================================
# Elon MEME Bot — Environment Config
# ==========================================

# ── Birdeye API ───────────────────────────
BIRDEYE_API_KEY=your_birdeye_api_key_here

# ── Helius RPC ────────────────────────────
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key_here
HELIUS_API_KEY=your_helius_api_key_here

# ── Jupiter API ───────────────────────────
JUPITER_API_URL=https://api.jup.ag
JUPITER_API_KEY=your_jupiter_api_key_here

# ── X (Twitter) API ───────────────────────
# Bearer Token（X Developer Portal → Projects & Apps → Keys and Tokens）
# 需要 Basic 计划($100/月)才能稳定拉到用户推文
X_BEARER_TOKEN=your_x_bearer_token_here

# Elon 推文刷新间隔（秒），建议 60
ELON_POLL_SEC=60

# 推文时间窗口（小时），只分析这段时间内的推文
# 0.5 = 30分钟（推荐：MEME 通常在 Elon 发推后 30 分钟内快速发射）
ELON_WINDOW_HOURS=0.5

# ── Grok (xAI) API ───────────────────────────
# xAI 控制台获取: https://console.x.ai
GROK_API_KEY=your_grok_api_key_here

# 模型选择：grok-4-1-fast（默认，速度快）或 grok-4（更强）
GROK_MODEL=grok-4-1-fast

# 关联评分阈值（0~1），达到此分数才买入
# 0.6 = 中等置信度，建议先用 0.65 以上
SCORE_THRESHOLD=0.65

# ── Trading Wallet ────────────────────────
WALLET_PRIVATE_KEY=your_base58_private_key_here

# ── Trade sizing ──────────────────────────
# 每次买入固定消耗的 SOL 数量
TRADE_SIZE_SOL=2

# ── Slippage ──────────────────────────────
# 初始滑点 bps（100=1%，500=5%）
# 失败会自动以 ×1.5 递增，最大 2000bps (20%)
SLIPPAGE_BPS=500

# ── Dedup ─────────────────────────────────
# 同一合约地址在此秒数内不重复处理（防止 webhook 重发）
DEDUP_SEC=300

# ── Price polling ─────────────────────────
# 持仓价格轮询间隔（秒），用于更新 dashboard 浮动盈亏
PRICE_POLL_SEC=60

# ── Webshare 代理（解决服务器IP被Cloudflare封禁）────────────
# 方式一（推荐）：填入 API Key，启动时自动拉取代理凭证
#   API Key 在 Webshare 控制台 → API Keys 页面获取
WEBSHARE_API_KEY=your_webshare_api_key_here
#
# 方式二：手动填写代理用户名密码（在 Proxy → Overview 页面查看）
# WEBSHARE_PROXY_USERNAME=your_proxy_username
# WEBSHARE_PROXY_PASSWORD=your_proxy_password
#
# 代理入口固定为 p.webshare.io:80，无需修改代码

# ── Server ────────────────────────────────
PORT=3001
