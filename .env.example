# ==========================================
# Elon MEME Bot — Environment Config
# ==========================================

# ── Birdeye API ───────────────────────────
BIRDEYE_API_KEY=your_birdeye_api_key_here

# ── Helius RPC ────────────────────────────
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key_here
HELIUS_API_KEY=your_helius_api_key_here

# ── Jupiter API ───────────────────────────
JUPITER_API_URL=https://api.jup.ag
JUPITER_API_KEY=your_jupiter_api_key_here

# ── X (Twitter) API ───────────────────────
# Bearer Token（X Developer Portal → Projects & Apps → Keys and Tokens）
# 需要 Basic 计划($100/月)才能稳定拉到用户推文
X_BEARER_TOKEN=your_x_bearer_token_here

# Elon 推文刷新间隔（秒），建议 60
ELON_POLL_SEC=60

# 推文时间窗口（小时），只分析这段时间内的推文
# 0.5 = 30分钟（推荐：MEME 通常在 Elon 发推后 30 分钟内快速发射）
ELON_WINDOW_HOURS=0.5

# ── DeepSeek API ─────────────────────────────
# 控制台获取: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 模型选择：deepseek-chat（DeepSeek-V3，默认）或 deepseek-reasoner（R1，更强但较慢）
DEEPSEEK_MODEL=deepseek-chat

# 关联评分阈值（0~1），达到此分数才买入
# 0.6 = 中等置信度，建议先用 0.65 以上
SCORE_THRESHOLD=0.65

# ── Trading Wallet ────────────────────────
WALLET_PRIVATE_KEY=your_base58_private_key_here

# ── Trade sizing ──────────────────────────
# 每次买入固定消耗的 SOL 数量
TRADE_SIZE_SOL=2

# ── Slippage ──────────────────────────────
# 初始滑点 bps（100=1%，500=5%）
# 失败会自动以 ×1.5 递增，最大 2000bps (20%)
SLIPPAGE_BPS=500

# ── Dedup ─────────────────────────────────
# 同一合约地址在此秒数内不重复处理（防止 webhook 重发）
DEDUP_SEC=300

# ── Price polling ─────────────────────────
# 持仓价格轮询间隔（秒），用于更新 dashboard 浮动盈亏
PRICE_POLL_SEC=60

# ── Server ────────────────────────────────
PORT=3001
